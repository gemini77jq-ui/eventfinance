# ===================================================================
# Claude Code Orchestrator Kit - .gitignore
# ===================================================================

# ===================================================================
# Sensitive Files - NEVER COMMIT THESE
# ===================================================================
# Server security documentation (contains private server info)
docs/SERVER-SECURITY-CHECKLIST.md

# Environment files with credentials
.env.local
.env.*.local
*.env.local

# Local MCP configuration (for personal credentials)
.mcp.local.json

# Local settings
.claude/settings.local.json

# ===================================================================
# Temporary Files
# ===================================================================
# Claude Code temporary files
.tmp/
*.tmp
.cache/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===================================================================
# Dependencies
# ===================================================================
node_modules/
.pnp
.pnp.js

# ===================================================================
# Build & Distribution
# ===================================================================
dist/
build/
out/
.next/
.nuxt/
.vercel/

# ===================================================================
# Testing
# ===================================================================
coverage/
.nyc_output/
*.lcov

# ===================================================================
# OS Files
# ===================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ===================================================================
# IDE & Editors
# ===================================================================
# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# JetBrains
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# ===================================================================
# Project Specific
# ===================================================================
# Git worktrees
.worktrees/

# Backup files
*.backup
*.bak
*.old
.claude/commands.backup.*/
.specify.backup.*/

# Archive files
*.archive

# Lock files (optional - uncomment if needed)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
*.tgz

# ===================================================================
# Articles & Writing
# ===================================================================
# Article drafts and master prompts (not for publication)
articles/

# Content agents (temporary/helper agents for writing)
.claude/agents/content/

# ===================================================================
# Spec-Kit Temporary
# ===================================================================
# Original spec-kit clone (for comparison)
/tmp/spec-kit-comparison/
.cache-config.md

# ===================================================================
# Beads Issue Tracker
# ===================================================================
# Data files (initialized per-project, not template)
.beads/issues.jsonl
.beads/beads.db
.beads/daemon.log
.beads/metadata.json
.beads/locks.json
.beads/*.lock

# Keep these (config and formulas) if project uses Beads:
# !.beads/config.yaml
# !.beads/formulas/
# !.beads/PRIME.md
# !.beads/README.md
