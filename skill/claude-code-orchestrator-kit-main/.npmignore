# ===================================================================
# NPM Publish Exclusions
# ===================================================================
# Only publish what's needed for users to use the kit

# ===================================================================
# Sensitive & Local Files (NEVER PUBLISH)
# ===================================================================
.env.local
.env.*.local
*.env.local
.mcp.local.json
.claude/settings.local.json

# ===================================================================
# Development & Build Files
# ===================================================================
.tmp/
*.tmp
.cache/
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
node_modules/

# ===================================================================
# Git & Version Control
# ===================================================================
.git/
.gitignore
.gitattributes
.github/workflows/
.worktrees/

# ===================================================================
# Testing & Coverage
# ===================================================================
coverage/
.nyc_output/
*.lcov
test/
tests/
*.test.js
*.spec.js

# ===================================================================
# OS & IDE Files
# ===================================================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ===================================================================
# Build Output (not needed for template)
# ===================================================================
dist/
build/
out/

# ===================================================================
# Package Manager Lock Files (users will generate their own)
# ===================================================================
package-lock.json
yarn.lock
pnpm-lock.yaml

# ===================================================================
# Documentation (keep main docs, exclude internal)
# ===================================================================
docs/reports/

# ===================================================================
# Backup & Archive Files
# ===================================================================
*.backup
*.bak
*.old
*.archive
